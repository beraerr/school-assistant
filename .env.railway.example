# ──────────────────────────────────────────────
# Railway Environment Variables — BACKEND service
# Bu değerleri Railway dashboard > Variables bölümüne gir
# ──────────────────────────────────────────────

# Railway PostgreSQL plugin'i ekleyince otomatik gelir:
DATABASE_URL=postgresql://<user>:<pass>@<host>:<port>/<db>

# Anthropic API key (Railway dashboard'dan gizli olarak gir)
ANTHROPIC_API_KEY=sk-ant-...
LLM_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-sonnet-4-6

# JWT secret — güçlü rastgele bir string gir
SECRET_KEY=<buraya-guclu-bir-secret-gir>

DEBUG=false

# ──────────────────────────────────────────────
# Railway Environment Variables — FRONTEND service
# ──────────────────────────────────────────────

# Backend servisinin Railway URL'si (deploy sonrası otomatik gelir)
API_BASE_URL=https://<backend-service-name>.up.railway.app
